@model MedCore.Web.ViewModels.PatientViewModel

@{
    ViewData["Title"] = "Register Patient";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Patient Management</h1>
    <ol class="breadcrumb mb-4 shadow-sm p-3 bg-white rounded">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">New Patient Registration</li>
    </ol>

    <div class="row justify-content-center">
        <div class="col-xl-7 col-lg-9">
            <div class="card mb-4 shadow border-0">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-2 rounded me-3">
                        <i class="fas fa-user-injured text-success fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Patient Registration</h5>
                        <small class="text-muted">Enter the basic details of the new patient</small>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 py-2 small" role="alert"></div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Name" class="form-label small fw-bold text-secondary text-uppercase"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light border-light text-muted"><i class="fas fa-user"></i></span>
                                    <input asp-for="Name" class="form-control border-light" placeholder="e.g. Michael Smith" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger x-small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Phone" class="form-label small fw-bold text-secondary text-uppercase"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light border-light text-muted"><i class="fas fa-mobile-alt"></i></span>
                                    <input asp-for="Phone" class="form-control border-light" placeholder="e.g. 01012345678" />
                                </div>
                                <span asp-validation-for="Phone" class="text-danger x-small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="border-top pt-4 mt-2 d-flex justify-content-between">
                            <a class="btn btn-outline-secondary px-4 py-2" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-arrow-left me-1"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-success px-5 py-2 shadow border-0">
                                <i class="fas fa-user-plus me-1"></i> Register Patient
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    .x-small {
        font-size: 0.75rem;
    }

    .form-control:focus, .form-select:focus {
        border-color: #198754;
        box-shadow: 0 0 0 0.25rem rgba(25, 135, 84, 0.1);
    }

    .input-group-text {
        border-right: none;
    }

    .form-control, .textarea {
        border-left: none;
    }
</style>