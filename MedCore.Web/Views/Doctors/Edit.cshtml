@model MedCore.Web.ViewModels.DoctorViewModel

@{
    ViewData["Title"] = "Edit Doctor";
}

<div class="container-fluid px-4">
    <h3 class="mt-4">Edit Doctor Profile</h3>

    <div class="card mb-4 shadow-sm border-0">
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Name" class="form-label text-muted small fw-bold"></label>
                        <input asp-for="Name" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Phone" class="form-label text-muted small fw-bold"></label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="SpecialtyId" class="form-label text-muted small fw-bold"></label>
                        <select asp-for="SpecialtyId" class="form-select" asp-items="ViewBag.Specialties"></select>
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    <a asp-action="Index" class="btn btn-light ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>