@model MedCore.Domain.Entities.Doctor

@{
    ViewData["Title"] = "Doctor Profile";
}

<div class="container-fluid px-4">
    <div class="mt-4 mb-4">
        <a asp-action="Index" class="btn btn-light shadow-sm text-muted fw-bold">
            <i class="fas fa-arrow-left me-2"></i> Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 text-center pt-4 pb-3">
                <div class="card-body">
                    <img src="https://ui-avatars.com/api/?name=@Model.Name&background=0d6efd&color=fff&size=120" class="rounded-circle shadow-sm mb-3" alt="Doctor" />
                    <h4 class="fw-bold mb-1">Dr. @Model.Name</h4>
                    <p class="text-muted"><i class="fas fa-stethoscope me-1"></i> @(Model.Specialty?.Name ?? "No Specialty")</p>

                    <div class="d-flex justify-content-center gap-2 mt-3">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 shadow-sm">Edit Profile</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
                    <h5 class="fw-bold"><i class="fas fa-info-circle text-primary me-2"></i> Contact Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mt-3">
                        <tbody>
                            <tr>
                                <td class="text-muted fw-bold w-25">Doctor ID:</td>
                                <td class="fw-bold text-dark">#@Model.Id</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-bold">Phone Number:</td>
                                <td class="fw-bold text-dark"><i class="fas fa-phone-alt text-success me-2"></i> @Model.Phone</td>
                            </tr>
                            <tr>
                                <td class="text-muted fw-bold">Department:</td>
                                <td><span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">@(Model.Specialty?.Name ?? "N/A")</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>