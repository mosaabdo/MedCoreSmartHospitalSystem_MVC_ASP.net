@model MedCore.Web.ViewModels.DoctorViewModel

@{
    ViewData["Title"] = "Add New Doctor";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Doctors Management</h1>
    <ol class="breadcrumb mb-4 shadow-sm p-3 bg-white rounded">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item"><a asp-controller="Doctors" asp-action="Index">Doctors List</a></li>
        <li class="breadcrumb-item active">New Registration</li>
    </ol>

    <div class="row justify-content-center">
        <div class="col-xl-7 col-lg-9">
            <div class="card mb-4 shadow border-0">
                <div class="card-header bg-white py-3 border-bottom d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                        <i class="fas fa-user-md text-primary fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Doctor Registration</h5>
                        <small class="text-muted">Enter the details of the new medical staff member</small>
                    </div>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 py-2 small" role="alert"></div>

                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <label asp-for="Name" class="form-label small fw-bold text-secondary text-uppercase"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light border-light text-muted"><i class="fas fa-user"></i></span>
                                    <input asp-for="Name" class="form-control border-light" placeholder="e.g. Dr. Robert Wilson" />
                                </div>
                                <span asp-validation-for="Name" class="text-danger x-small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="Phone" class="form-label small fw-bold text-secondary text-uppercase"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light border-light text-muted"><i class="fas fa-phone"></i></span>
                                    <input asp-for="Phone" class="form-control border-light" placeholder="e.g. +1 555 123 4567" />
                                </div>
                                <span asp-validation-for="Phone" class="text-danger x-small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="SpecialtyId" class="form-label small fw-bold text-secondary text-uppercase"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light border-light text-muted"><i class="fas fa-stethoscope"></i></span>
                                    <select asp-for="SpecialtyId" class="form-select border-light" asp-items="ViewBag.Specialties">
                                        <option value="">-- Choose Specialty --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="SpecialtyId" class="text-danger x-small mt-1 d-block"></span>
                            </div>
                        </div>

                        <div class="border-top pt-4 mt-2 d-flex justify-content-between">
                            <a class="btn btn-outline-secondary px-4 py-2" asp-controller="Doctors" asp-action="Index">
                                <i class="fas fa-arrow-left me-1"></i> Back to List
                            </a>
                            <button type="submit" class="btn btn-primary px-5 py-2 shadow border-0">
                                <i class="fas fa-save me-1"></i> Save Doctor Record
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

<style>
    /* Mimicking the professional look from your dashboard screenshots */
    .x-small { font-size: 0.75rem; }
    .form-control:focus, .form-select:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }
    .card { transition: transform 0.2s ease; }
    .input-group-text { border-right: none; }
    .form-control, .form-select { border-left: none; }
</style>