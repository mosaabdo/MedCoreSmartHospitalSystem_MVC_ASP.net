@model MedCore.Web.ViewModels.SpecialtyViewModel

@{
    ViewData["Title"] = Model?.Id > 0 ? "Edit Specialty" : "Add Specialty";
}

<div class="container-fluid px-4">
    <h3 class="mt-4">@ViewData["Title"]</h3>
    
    <div class="card mb-4 shadow-sm border-0 col-lg-6">
        <div class="card-body p-4">
            <form method="post"> 
                @if (Model?.Id > 0)
                {
                    <input type="hidden" asp-for="Id" />
                }
                
                <div class="mb-3">
                    <label asp-for="Name" class="form-label text-muted small fw-bold"></label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-light"><i class="fas fa-tags text-muted"></i></span>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Cardiology" />
                    </div>
                    <span asp-validation-for="Name" class="text-danger x-small mt-1"></span>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-dark px-4 shadow-sm">Save Specialty</button>
                    <a asp-action="Index" class="btn btn-light ms-2">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}