@model MedCore.Domain.Entities.Specialty

@{
    ViewData["Title"] = "Specialty Details";
}

<div class="container-fluid px-4">
    <div class="mt-4 mb-4">
        <a asp-action="Index" class="btn btn-light shadow-sm text-muted fw-bold">
            <i class="fas fa-arrow-left me-2"></i> Back to Specialties
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-primary text-white">
        <div class="card-body d-flex align-items-center p-4">
            <i class="fas fa-heartbeat fs-1 border-end pe-4 me-4 border-white-50"></i>
            <div>
                <h2 class="fw-bold mb-0">@Model.Name Department</h2>
                <p class="mb-0 text-white-50">Manage doctors assigned to this specialty</p>
            </div>
        </div>
    </div>

    <h5 class="fw-bold mb-3"><i class="fas fa-user-md text-primary me-2"></i> Doctors in @Model.Name</h5>
    
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">ID</th>
                            <th>Doctor Name</th>
                            <th>Phone</th>
                            <th class="text-end pe-4">Profile</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Doctors != null && Model.Doctors.Any())
                        {
                            foreach (var doctor in Model.Doctors)
                            {
                                <tr>
                                    <td class="ps-4 text-muted fw-bold">#@doctor.Id</td>
                                    <td class="fw-bold text-dark">Dr. @doctor.Name</td>
                                    <td>@doctor.Phone</td>
                                    <td class="text-end pe-4">
                                        <a asp-controller="Doctors" asp-action="Details" asp-route-id="@doctor.Id" class="btn btn-sm btn-outline-primary">
                                            View Profile
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    <i class="fas fa-user-slash fs-3 mb-2"></i>
                                    <p class="mb-0">No doctors are currently assigned to this specialty.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>