@model MedCore.Web.ViewModels.SpecialtyViewModel
@{
    ViewData["Title"] = "Add Specialty";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Settings</h1>
    <div class="row justify-content-center">
        <div class="col-xl-6">
            <div class="card shadow-sm border-0 mt-5">
                <div class="card-header bg-white py-3">
                    <i class="fas fa-tags me-1 text-primary"></i>
                    <strong>Add New Medical Specialty</strong>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post">
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label small fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Cardiology, Pediatrics..." />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary px-5">Save Specialty</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>