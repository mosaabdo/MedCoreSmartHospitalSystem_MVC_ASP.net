@model MedCore.Domain.Entities.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container-fluid px-4">
    <div class="mt-4 mb-4">
        <a asp-action="Index" class="btn btn-light shadow-sm text-muted fw-bold">
            <i class="fas fa-arrow-left me-2"></i> Back to Appointments
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3 d-flex align-items-center">
                    <i class="fas fa-calendar-check fs-4 me-3"></i>
                    <h5 class="mb-0 fw-bold">Appointment Information</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-6 border-end">
                            <h6 class="text-muted text-uppercase small fw-bold mb-3">Patient Details</h6>
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-light rounded-circle p-2 me-3">
                                    <i class="fas fa-user-injured text-primary fs-5"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0 text-dark">@Model.Patient?.Name</h5>
                                    <small class="text-muted"><i class="fas fa-phone-alt me-1"></i> @Model.Patient?.Phone</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 ps-4">
                            <h6 class="text-muted text-uppercase small fw-bold mb-3">Doctor Details</h6>
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-light rounded-circle p-2 me-3">
                                    <i class="fas fa-user-md text-success fs-5"></i>
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-0 text-dark">Dr. @Model.Doctor?.Name</h5>
                                    <small class="text-muted"><i class="fas fa-stethoscope me-1"></i> @Model.Doctor?.Specialty?.Name</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-light rounded p-3 mb-4">
                        <div class="row text-center">
                            <div class="col-6 border-end">
                                <span class="text-muted d-block small fw-bold">Date</span>
                                <span class="fs-5 fw-bold text-dark">@Model.AppointmentDate.ToString("dd MMM, yyyy")</span>
                            </div>
                            <div class="col-6">
                                <span class="text-muted d-block small fw-bold">Time</span>
                                <span class="fs-5 fw-bold text-primary">@Model.AppointmentDate.ToString("hh:mm tt")</span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <h6 class="text-muted text-uppercase small fw-bold mb-2">Notes / Reason for visit</h6>
                        <div class="p-3 border rounded bg-white">
                            @(string.IsNullOrWhiteSpace(Model.Notes) ? "No notes provided for this appointment." : Model.Notes)
                        </div>
                    </div>

                    <div class="mt-4 text-center">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 me-2 shadow-sm">
                            <i class="fas fa-edit me-1"></i> Edit Appointment
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>