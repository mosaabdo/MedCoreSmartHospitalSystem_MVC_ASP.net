@model MedCore.Web.ViewModels.BookAppointmentViewModel

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Appointments Management</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Dashboard</a></li>
        <li class="breadcrumb-item active">New Appointment</li>
    </ol>

    <div class="row justify-content-center">
        <div class="col-xl-8">
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-white py-3 border-bottom">
                    <i class="fas fa-calendar-alt me-1 text-primary"></i>
                    <strong class="text-uppercase text-muted small">Appointment Booking Form</strong>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Book" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label small fw-bold text-muted">Specialty</label>
                                <select id="SpecialtyId" class="form-select border-light shadow-sm" asp-items="ViewBag.Specialties">
                                    <option value="">-- Select Specialty First --</option>
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="DoctorId" class="form-label small fw-bold text-muted"></label>
                                <select asp-for="DoctorId" id="DoctorId" class="form-select border-light shadow-sm">
                                    <option value="">-- Waiting for Specialty --</option>
                                </select>
                                <span asp-validation-for="DoctorId" class="text-danger x-small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="PatientId" class="form-label small fw-bold text-muted"></label>
                                <select asp-for="PatientId" class="form-select border-light shadow-sm" asp-items="ViewBag.Patients">
                                    <option value="">-- Select Patient --</option>
                                </select>
                                <span asp-validation-for="PatientId" class="text-danger x-small"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="AppointmentDate" class="form-label small fw-bold text-muted"></label>
                                <input asp-for="AppointmentDate" type="datetime-local" class="form-control border-light shadow-sm" />
                                <span asp-validation-for="AppointmentDate" class="text-danger x-small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ChronicConditions" class="form-label small fw-bold text-muted"></label>
                            <textarea asp-for="ChronicConditions" class="form-control border-light shadow-sm" rows="2" placeholder="Mention any chronic diseases..."></textarea>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label small fw-bold text-muted"></label>
                            <textarea asp-for="Notes" class="form-control border-light shadow-sm" rows="3" placeholder="Additional notes..."></textarea>
                        </div>

                        <div class="d-flex align-items-center justify-content-between pt-2">
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Confirm Booking</button>
                            <a class="btn btn-link text-muted text-decoration-none" asp-action="Index" asp-controller="Home">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $('#SpecialtyId').change(function () {
                var selectedSpecialtyId = $(this).val();
                var doctorDropdown = $('#DoctorId');

                // مسح قائمة الأطباء القديمة
                doctorDropdown.empty();
                doctorDropdown.append('<option value="">-- Select Doctor --</option>');

                // إرسال الطلب في حالة اختيار تخصص
                if (selectedSpecialtyId) {
                    $.ajax({
                        url: '/Doctors/GetDoctorsBySpecialty', // مسار الدالة في الكنترولر
                        type: 'GET',
                        data: { specialtyId: selectedSpecialtyId },
                        success: function (data) {
                            // تعبئة القائمة بالبيانات الراجعة
                            $.each(data, function (index, doctor) {
                                doctorDropdown.append('<option value="' + doctor.id + '">' + doctor.name + '</option>');
                            });
                        },
                        error: function () {
                            alert("Something went wrong while fetching doctors!");
                        }
                    });
                }
            });
        });
    </script>
}