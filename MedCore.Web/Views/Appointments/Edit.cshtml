@model MedCore.Web.ViewModels.EditAppointmentViewModel

@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="container-fluid px-4">
    <h3 class="mt-4 mb-4 fw-bold">Reschedule / Edit Appointment</h3>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PatientId" class="form-label fw-bold text-muted small"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light"><i class="fas fa-user-injured text-muted"></i></span>
                                    <select asp-for="PatientId" class="form-select" asp-items="ViewBag.Patients">
                                        <option value="">-- Select Patient --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="PatientId" class="text-danger x-small mt-1"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="DoctorId" class="form-label fw-bold text-muted small"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light"><i class="fas fa-user-md text-muted"></i></span>
                                    <select asp-for="DoctorId" class="form-select" asp-items="ViewBag.Doctors">
                                        <option value="">-- Select Doctor --</option>
                                    </select>
                                </div>
                                <span asp-validation-for="DoctorId" class="text-danger x-small mt-1"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label asp-for="AppointmentDate" class="form-label fw-bold text-muted small"></label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-light"><i class="far fa-calendar-alt text-muted"></i></span>
                                    <input asp-for="AppointmentDate" class="form-control" type="datetime-local" />
                                </div>
                                <span asp-validation-for="AppointmentDate" class="text-danger x-small mt-1"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12 mb-4">
                                <label asp-for="Notes" class="form-label fw-bold text-muted small">Notes (Optional)</label>
                                <textarea asp-for="Notes" class="form-control shadow-sm" rows="3" placeholder="Add any special instructions or reason for visit..."></textarea>
                                <span asp-validation-for="Notes" class="text-danger x-small mt-1"></span>
                            </div>
                        </div>

                        <div class="border-top pt-4 d-flex justify-content-end">
                            <a asp-action="Index" class="btn btn-light me-2 fw-bold">Cancel</a>
                            <button type="submit" class="btn btn-primary px-4 shadow-sm fw-bold">
                                <i class="fas fa-save me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4 d-none d-lg-block">
            <div class="card bg-light border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-bold text-primary"><i class="fas fa-info-circle me-2"></i> Note on Rescheduling</h6>
                    <p class="small text-muted mb-0">
                        When changing the doctor or the appointment time, the system will automatically check if the new time slot is available for the selected doctor. If there is a conflict, you will be notified.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}